{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Cursor MCP config (.cursor/mcp.json). Lenient -- tolerates extra fields, no type required.",
  "type": "object",
  "required": ["mcpServers"],
  "properties": {
    "mcpServers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": {"type": "string"},
          "args": {"type": "array", "items": {"type": "string"}},
          "env": {"type": "object", "additionalProperties": {"type": "string"}}
        }
      }
    }
  }
}
